# paper: 실제 주문 없이 실시간 시세로 가상 매매 (기본값)
# testnet: Binance Spot Test Network에 가상자산 주문
TRADING_MODE=paper

SYMBOL=BTC/USDT
TIMEFRAME=1h
FAST_PERIOD=20
SLOW_PERIOD=50
QUOTE_AMOUNT=25
POLL_SECONDS=30
# 최신 확정봉이 이 시간보다 오래됐으면 과거 신호를 뒤늦게 주문하지 않습니다.
MAX_SIGNAL_AGE_SECONDS=600

# paper 모드 설정
PAPER_STARTING_QUOTE=1000
PAPER_FEE_RATE=0.001

# 신규 매수만 차단하는 일일 실현손실 한도. 0이면 비활성화.
MAX_DAILY_LOSS_USDT=10

# 선택 사항: 확정봉 종가 기준 손절. 0이면 비활성화. 예: 0.03 = 3%
CLOSE_STOP_LOSS_PCT=0

STATE_FILE=./data/state.json
LOG_LEVEL=INFO

# testnet에서만 필요
BINANCE_API_KEY=
BINANCE_API_SECRET=
